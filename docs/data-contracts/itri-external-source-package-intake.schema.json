  ],
  "$defs": {
    "ownerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization",
        "role",
        "authorityScope"
      ],
      "properties": {
        "organization": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "authorityScope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "retainedPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._@+\\-/]+$"
    },
    "checksum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "sha256",
            "sha384",
            "sha512",
            "owner-defined"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "packageArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "artifactKind",
        "retainedPath",
        "checksum",
        "retentionClass",
        "sourceRole"
      ],
      "properties": {
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "artifactKind": {
          "enum": [
            "raw-source",
            "source-metadata",
            "checksum-manifest",
            "license-or-redistribution-policy",
            "owner-approval",
            "scenario-mapping",
            "parsed-field-review",
            "redaction-note",
            "other"
          ]
        },
        "retainedPath": {
          "$ref": "#/$defs/retainedPath"
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "retentionClass": {
          "enum": [
            "repo-retainable",
            "private-owner-retained",
            "metadata-only",
            "redacted-retainable"
          ]
        },
        "sourceRole": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "sourceArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "refPurpose"
      ],
      "properties": {
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "refPurpose": {
          "type": "string",
          "minLength": 1
        },
        "fieldPath": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "sourceArtifactRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceArtifactRef"
      }
    },
    "modeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "allowedUse",
        "executionRequiredForIntakeReview",
        "unavailableBehavior",
        "malformedDataBehavior",
        "outsideEpochBehavior",
        "sourceArtifactRefs"
      ],
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "allowedUse": {
          "type": "string",
          "minLength": 1
        },
        "executionRequiredForIntakeReview": {
          "const": false
        },
        "unavailableBehavior": {
          "enum": [
            "reject-package",
            "mark-incomplete",
            "fallback-to-prerecorded-only",
            "owner-review-required"
          ]
        },
        "malformedDataBehavior": {
          "enum": [
            "reject-record",
            "reject-package",
            "quarantine-records",
            "owner-review-required"
          ]
        },
        "outsideEpochBehavior": {
          "enum": [
            "reject-record",
            "reject-package",
            "mark-stale",
            "owner-review-required"
          ]
        },
        "sourceArtifactRefs": {
          "$ref": "#/$defs/sourceArtifactRefs"
        }
      }
    },
    "scenarioRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "sourceField",
        "targetField",
        "rule",
        "sourceArtifactRefs"
      ],
      "properties": {
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "sourceField": {
          "type": "string",
          "minLength": 1
        },
        "targetField": {
          "type": "string",
          "minLength": 1
        },
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "sourceArtifactRefs": {
          "$ref": "#/$defs/sourceArtifactRefs"
        }
      }
    },
    "parsedReviewedField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fieldPath",
        "fieldPurpose",
        "reviewedValueKind",
        "reviewRule",
        "sourceArtifactRefs"
      ],
      "properties": {
        "fieldPath": {
          "type": "string",
          "minLength": 1
        },
        "fieldPurpose": {
          "type": "string",
          "minLength": 1
        },
        "reviewedValueKind": {
          "type": "string",
          "minLength": 1
        },
        "reviewRule": {
          "type": "string",
          "minLength": 1
        },
        "sourceArtifactRefs": {
          "$ref": "#/$defs/sourceArtifactRefs"
        }
      }
    },
    "reviewerNote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noteId",
        "note",
        "sourceArtifactRefs"
      ],
      "properties": {
        "noteId": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "sourceArtifactRefs": {
          "$ref": "#/$defs/sourceArtifactRefs"
        }
      }
    },
    "nonClaims": {
      "type": "object",
      "additionalProperties": false,
      "description": "All fields are literal false. Omission or true must fail closed.",
      "required": [
        "closesF01ItriOrbitModelIntegration",
        "arbitraryExternalSourceAcceptance",
        "liveRealTimeFeedExecution",
        "measuredTrafficNetworkTruth",
        "natTunnelDutValidation",
        "nativeRfHandoverTruth",
        "completeItriAcceptance",
        "publicCelesTrakOrSpaceTrackSubstitutesForItriPrivateSourceAuthorityWithoutOwnerEvidence"
      ],
      "properties": {
        "closesF01ItriOrbitModelIntegration": {
          "const": false,
          "description": "The package does not close F-01 customer orbit-model integration."
        },
        "arbitraryExternalSourceAcceptance": {
          "const": false,
          "description": "The package does not approve arbitrary external sources outside the declared owner scope."
        },
        "liveRealTimeFeedExecution": {
          "const": false,
          "description": "The package does not prove live real-time feed execution."
        },
        "measuredTrafficNetworkTruth": {
          "const": false,
          "description": "The package does not assert measured traffic or network truth."
        },
        "natTunnelDutValidation": {
          "const": false,
          "description": "The package does not validate NAT, tunnel, or DUT paths."
        },
        "nativeRfHandoverTruth": {
          "const": false,
          "description": "The package does not assert native radio-frequency handover truth."
        },
        "completeItriAcceptance": {
          "const": false,
          "description": "The package does not claim complete acceptance by customer."
        },
        "publicCelesTrakOrSpaceTrackSubstitutesForItriPrivateSourceAuthorityWithoutOwnerEvidence": {
          "const": false,
          "description": "Public CelesTrak or Space-Track material cannot replace customer private source authority unless explicit owner evidence is retained for that exact scope."
        }
      }
    }
  }
}
