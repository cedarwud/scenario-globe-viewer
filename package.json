{
  "name": "scenario-globe-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "npm run build && node scripts/verify-phase0.mjs",
    "test:phase1": "node scripts/site-hook-guard.mjs --context=phase1-baseline && npm run build && node tests/smoke/bootstrap-loads-assets-and-workers.mjs --suite=baseline",
    "test:phase1:showcase": "node scripts/phase1-cleanup-orchestration.mjs --flow=showcase",
    "test:phase1:site-dataset": "node scripts/phase1-cleanup-orchestration.mjs --flow=site-dataset",
    "test:phase1:site-hook-conflict": "node scripts/phase1-cleanup-orchestration.mjs --flow=site-hook-conflict",
    "test:phase3.2": "node scripts/verify-phase3.2-replay-clock-contract.mjs",
    "test:phase3.3": "npm run build && node tests/smoke/verify-phase3.3-replay-clock-real-time.mjs",
    "test:phase3.4": "npm run build && node tests/smoke/verify-phase3.4-replay-clock-prerecorded.mjs",
    "test:phase3.5": "npm run build && node tests/smoke/verify-phase3.5-timeline-hud-placeholder.mjs",
    "test:phase3.6": "node scripts/verify-phase3.6-overlay-manager-contract.mjs",
    "test:phase3.7": "node scripts/verify-phase3.7-satellite-overlay-contract.mjs",
    "test:phase4.1": "node scripts/verify-phase4.1-walker-fixture-adapter.mjs",
    "test:phase5.1": "npm run build && node tests/smoke/bootstrap-loads-assets-and-workers.mjs --suite=overlay-toggle",
    "test:phase6.1": "node scripts/verify-phase6.1-scenario-coordination.mjs",
    "test:phase6.1:overlay-seeds": "node scripts/verify-phase6.1-overlay-seed-contracts.mjs",
    "test:phase6.2": "npm run build && node scripts/verify-phase6.2-bootstrap-operator-controls.mjs && node tests/smoke/verify-phase6.2-bootstrap-operator-controls.mjs",
    "test:phase6.3": "npm run build && node scripts/verify-phase6.3-bootstrap-communication-time.mjs && node tests/smoke/verify-phase6.3-bootstrap-communication-time.mjs",
    "test:phase6.4": "npm run build && node scripts/verify-phase6.4-bootstrap-handover-decision.mjs && node tests/smoke/verify-phase6.4-bootstrap-handover-decision.mjs",
    "test:phase6.5": "npm run build && node scripts/verify-phase6.5-bootstrap-physical-input.mjs && node tests/smoke/verify-phase6.5-bootstrap-physical-input.mjs",
    "test:phase6.6": "npm run build && node scripts/verify-phase6.6-bootstrap-validation-state.mjs && node tests/smoke/verify-phase6.6-bootstrap-validation-state.mjs",
    "test:phase6.7": "npm run build && node tests/smoke/verify-phase6.7-bootstrap-scene-starter.mjs",
    "test:phase7.0:rehearsal": "node scripts/run-phase7.0-soak.mjs --profile rehearsal",
    "test:phase7.0:full": "node scripts/run-phase7.0-soak.mjs --profile full",
    "test:phase7.1": "npm run build && node tests/smoke/verify-m7-slice-a-first-intake-active-case-narrative-runtime.mjs",
    "test:r1v.1": "npm run build && node tests/smoke/verify-r1v1-presentation-suppression-runtime.mjs",
    "test:r1v.2": "npm run build && node tests/smoke/verify-r1v2-time-authority-integration-runtime.mjs",
    "test:r1v.3": "npm run build && node tests/smoke/verify-r1v3-animated-cue-and-relation-runtime.mjs",
    "test:r1v.4": "npm run build && node tests/smoke/verify-r1v4-cinematic-camera-preset-runtime.mjs",
    "test:r1v.5": "npm run build && node tests/smoke/verify-r1v5-minimal-satcom-context-overlay-runtime.mjs",
    "test:r1v.visual": "npm run build && node tests/smoke/verify-r1v-visual-acceptance-runtime.mjs",
    "test:m8a-v3.3": "npm run build && node tests/smoke/verify-m8a-v3.3-autoplay-motion-runtime.mjs",
    "test:m8a-v3.4": "npm run build && node tests/smoke/verify-m8a-v3.4-close-view-camera-runtime.mjs && node tests/smoke/verify-m8a-v3.4-orbit-context-emphasis-runtime.mjs && node tests/smoke/verify-m8a-v3.4-overlay-placement-runtime.mjs",
    "test:m8a-v3.5": "npm run build && node tests/smoke/verify-m8a-v3.5-source-lineaged-orbit-context-actors-runtime.mjs",
    "test:m8a-v3.6": "npm run build && node tests/smoke/verify-m8a-v3.6-homepage-handover-entry-icon-runtime.mjs",
    "capture:phase2.12": "node scripts/site-hook-guard.mjs --context=phase2.12-capture && npm run build && node tests/visual/capture-three-preset-baselines.mjs",
    "capture:phase5.3-orbits": "node scripts/site-hook-guard.mjs --context=phase5.3-orbit-capture && npm run build && node tests/visual/capture-phase5.3-orbit-review.mjs",
    "capture:site-dataset": "node scripts/site-dataset-visual-orchestration.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "cesium": "1.140.0",
    "satellite.js": "7.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-static-copy": "^4.0.1"
  }
}
